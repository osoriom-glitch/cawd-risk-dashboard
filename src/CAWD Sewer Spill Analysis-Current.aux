\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Maintenance-cap sensitivity (SA2). Left: unconstrained allocation at \$550K budget; optimizer deploys only \$75K ($I_1$=0.5\,u, $I_4$=0.25\,u), leaving \$475K unspent. Right: allocation when $I_1$ is capped at \$300K (3.0\,u); full \$550K deployed across all four levers ($I_1$=3.0, $I_2$=0.5, $I_3$=1.5, $I_4$=0.5\,u). Dashed line marks the cap level. Red bar indicates the constrained lever.}}{16}{figure.caption.16}\protected@file@percent }
\newlabel{fig:sa2}{{5}{16}{Maintenance-cap sensitivity (SA2). Left: unconstrained allocation at \$550K budget; optimizer deploys only \$75K ($I_1$=0.5\,u, $I_4$=0.25\,u), leaving \$475K unspent. Right: allocation when $I_1$ is capped at \$300K (3.0\,u); full \$550K deployed across all four levers ($I_1$=3.0, $I_2$=0.5, $I_3$=1.5, $I_4$=0.5\,u). Dashed line marks the cap level. Red bar indicates the constrained lever}{figure.caption.16}{}}
